            "editorial",
            "earthbound"
          ],
          "description": "Canonical Style Remix palette id."
        },
        "scope": {
          "type": "string",
          "enum": [
            "selection",
            "board"
          ],
          "description": "Defaults to selection; whole-board remix must be explicit."
        },
        "ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional explicit Object ids for selection scope."
        }
