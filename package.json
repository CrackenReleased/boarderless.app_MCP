{
  "name": "@boarderless/mcp-server",
  "version": "0.1.20",
  "description": "Model Context Protocol (MCP) server for Boarderless, allowing AI agents to read the canvas state, mutate elements, and calculate export bounds.",
  "engines": { "node": ">=18" },
  "type": "module",
  "main": "src/mcp-stdio-server.js",
  "bin": {
    "boarderless-mcp-server": "./src/mcp-stdio-server.js"
  },
  "scripts": {
    "start": "node src/mcp-stdio-server.js",
    "example": "node src/index.js",
    "setup": "node src/setup.js",
    "tauri": "tauri",
    "test": "node src/verify_shortcut.js && node src/verify_nonblocking_auth.js",
    "verify:status": "node src/verify_nonblocking_auth.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "heic-convert": "^2.1.0",
    "jimp": "^0.22.12",
    "puppeteer-core": "^22.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "boarderless",
    "spatial-canvas",
    "puppeteer",
    "agentic-ui"
  ],
  "author": "CrackenReleased",
  "license": "Apache-2.0",
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  }
}
